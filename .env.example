PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/myplopplop
JWT_SECRET=your-secret-key-here
JWT_EXPIRE=7d
COMMISSION_RATE=0.25
UPLOAD_DIR=uploads
NODE_ENV=development
FRONTEND_URL=https://myplopplop.com

# SolutionIP (Pey'M PlopPlop) payment gateway
SOLUTIONIP_URL=https://plopplop.solutionip.app
SOLUTIONIP_CLIENT_ID=your-solutionip-client-id

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:info@myplopplop.com
